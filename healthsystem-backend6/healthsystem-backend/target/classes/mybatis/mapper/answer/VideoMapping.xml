<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nwpu.healthsystem.backend.mapper.answer.VideoMapper">
    <insert id="insertVideo" >
        insert into video
            (user_id,video_url)
        values
            (#{userId},#{videoUrl})
    </insert>

    <select id="getVideoListByPage" resultType="com.nwpu.healthsystem.backend.entity.answer.Video">
        select *
        from video
        where user_id=#{userId}
        ORDER BY id DESC
    </select>

    <update id="updateInference">
        update video
        set inference=#{inference},infer_cost=#{inferCost}
        where video_url = #{videoUrl}
    </update>

    <select id="getInferenceByDate" resultType="com.nwpu.healthsystem.backend.common.dto.echarts.Inference">
        select log_date, log_time, inference, infer_cost
        from video
        where user_id=#{userId} and log_date=#{date}
    </select>
</mapper>